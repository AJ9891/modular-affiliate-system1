# Environment Variables

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_AGENCY_PRICE_ID=price_xxx

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Email Provider Configuration
EMAIL_PROVIDER=autoresponder
EMAIL_DEFAULT_FROM=user@launchpad4success.pro
EMAIL_DEFAULT_FROM_NAME=Launchpad4Success
AUTORESPONDER_CRON_SECRET=replace_with_strong_secret
# Optional on Vercel Cron: set this to the same value as AUTORESPONDER_CRON_SECRET
CRON_SECRET=replace_with_same_strong_secret
PUBLISH_CRON_SECRET=replace_with_strong_secret

# Google Integration (optional for advanced keyword APIs)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/oauth/callback
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token

# AWS SES Configuration (for EMAIL_PROVIDER=ses)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
SES_CONFIGURATION_SET=launchpad-prod

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development

# Admin Features
# For admin credit topup - success/cancel URLs for Stripe checkout
# In production: https://launchpad4success.pro
ADMIN_EMAILS=you@example.com
