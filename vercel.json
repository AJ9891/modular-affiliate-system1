{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "cd apps/web && npm run build && node scripts/ensure-middleware-nft.mjs",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/email/autoresponder/run",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/publish/run",
      "schedule": "0 3 * * *"
    }
  ]
}
