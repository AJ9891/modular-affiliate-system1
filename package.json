{
  "name": "modular-affiliate-system",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.2.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:debug": "NODE_ENV=development DEBUG=* turbo run dev",
    "dev:web": "cd apps/web && npm run dev",
    "dev:web:debug": "cd apps/web && npm run dev:debug",
    "dev:web:verbose": "cd apps/web && npm run dev:verbose",
    "dev:enhanced": "cd apps/web && ./dev-server.sh",
    "build": "turbo run build",
    "build:debug": "NODE_ENV=development turbo run build:debug",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#**/node_modules/**\" \"#.next\" \"#.turbo\" \"#.vercel\"",
    "lint:md:fix": "markdownlint-cli2 \"**/*.md\" \"#**/node_modules/**\" \"#.next\" \"#.turbo\" \"#.vercel\" --fix",
    "repo:hygiene": "node scripts/check-repo-hygiene.js",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "deploy": "./scripts/vercel-safe-deploy.sh",
    "deploy:check": "./scripts/vercel-safe-deploy.sh --check",
    "deploy:preview": "./scripts/vercel-safe-deploy.sh --preview",
    "web": "npm run dev --workspace=apps/web",
    "admin": "npm run dev --workspace=apps/admin",
    "renderer": "npm run dev --workspace=apps/renderer",
    "mcp:talk-to-figma": "npx ai-figma-mcp@latest",
    "mcp:health": "echo \"TODO: replace with a real health check command\"",
    "mcp:logs": "# pipe or view logs depending on your process manager"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.21.0",
    "markdownlint-cli2-formatter-pretty": "^0.0.9",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.12"
    },
    "postcss": "^8.5.12"
  },
  "lint-staged": {
    "*.md": [
      "markdownlint-cli2 --fix"
    ]
  }
}
